# =============================================
# DEPTHGUARD - CONFIGURACIÓN
# Copiar como .env: copy .env.example .env
# =============================================

# --- CÁMARA ---
MODO_CAMARA=simulada

# --- SERVIDOR ---
PORT=8000

# --- URLs ---
FRONTEND_URL=https://depthguard-tesis.vercel.app
NGROK_DOMAIN=depthguard-tesis.ngrok-free.app
BACKEND_URL=https://depthguard-tesis.ngrok-free.app

# --- ANTI-SPOOFING ---
UMBRAL_VARIANZA=0.7
UMBRAL_RANGO_PROF=3.0
UMBRAL_SUAVIDAD=5.0
RANGO_DIST_MIN=25
RANGO_DIST_MAX=150
MIN_PIXELES_VALIDOS=0.30

# --- RECONOCIMIENTO ---
TOLERANCIA_FACIAL=0.55
COOLDOWN_EMBEDDING=2.0
COOLDOWN_ANTISPOOFING=0.3
COOLDOWN_EVENTO=5

# --- PUSH NOTIFICATIONS ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@depthguard.com

# --- ADMIN ---
ADMIN_USUARIO=admin
ADMIN_PASSWORD=admin123
