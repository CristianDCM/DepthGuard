# =============================================
# DEPTHGUARD - CONFIGURACIÓN (Nodo Edge)
# Copiar como .env: copy .env.example .env
# =============================================

# --- CÁMARA ---
MODO_CAMARA=simulada

# --- SUPABASE ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...tu-service-role-key...

# --- ANTI-SPOOFING ---
UMBRAL_VARIANZA=0.7
UMBRAL_RANGO_PROF=3.0
UMBRAL_SUAVIDAD=5.0
RANGO_DIST_MIN=25
RANGO_DIST_MAX=150
MIN_PIXELES_VALIDOS=0.30

# --- RECONOCIMIENTO ---
TOLERANCIA_FACIAL=0.55
COOLDOWN_EMBEDDING=2.0
COOLDOWN_ANTISPOOFING=0.3
COOLDOWN_EVENTO=5

# --- ADMIN (para seed inicial) ---
ADMIN_USUARIO=admin
ADMIN_PASSWORD=admin123

# --- WEBRTC / TURN (Metered) ---
# Registro gratuito en https://www.metered.ca
TURN_URL=turn:TU-APP.metered.live:80
TURN_USERNAME=tu_api_key_de_metered
TURN_CREDENTIAL=tu_api_key_de_metered
